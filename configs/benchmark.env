# =============================================================================
# Voting Platform - Benchmark Configuration
# =============================================================================

# Application Metadata
APP_PRODUCT_NAME=Voting Platform
APP_TAGLINE=Secure and observable voting
APP_DESCRIPTION=White-label voting platform with anti-abuse controls and observability.
APP_VOTE_PAGE_TITLE=Voting Platform - Vote
APP_ADMIN_PAGE_TITLE=Voting Platform - Admin
APP_API_SERVICE_TITLE=Voting Platform API
APP_EVENTS_TITLE=Voting Platform Events
APP_CONTRACT_BASE_URL=https://voting-platform.example/contracts

# Container & Network
CONTAINER_NAME_PREFIX=voting-platform-benchmark
COMPOSE_NETWORK_NAME=voting-platform-benchmark-network

# Network Binding
API_BIND_IP=127.0.0.1
API_PORT=8080
API_B_BIND_IP=127.0.0.1
API_B_PORT=8082

# API Instance A
API_HTTP_ADDR=:8080
API_KAFKA_BROKERS=kafka:9092
API_LOG_LEVEL=warn
API_FEATURE_POW_VOTE=false
API_POW_ALGORITHM=sha256
API_POW_TTL_SECONDS=60
API_POW_BASE_DIFFICULTY_BITS=18
API_POW_MAX_DIFFICULTY_BITS=24
API_POW_ADAPTIVE_WINDOW_SECONDS=60
API_POW_TARGET_MS=3000
API_ANTIABUSE_STORE=valkey
API_VALKEY_ADDR=valkey:6379
API_VALKEY_DB=0
API_VALKEY_KEY_PREFIX=voting-platform-benchmark
API_KAFKA_TOPIC_VOTES_RAW=votes.raw
API_KAFKA_TOPIC_VOTINGS_CATALOG=votings.catalog
API_KAFKA_TOPIC_POLICY_CONTROL=voting-policy-control
API_KAFKA_TOPIC_RESULTS_SNAPSHOT=voting-results-snapshot
API_KAFKA_TOPIC_VOTING_CATALOG_LATEST=voting-catalog-latest
API_KAFKA_TOPIC_VOTING_POLICY_LATEST=voting-policy-latest
API_EDGE_PROXY_AUTH_HEADER=X-App-Edge-Auth

# API Instance B
API_B_HTTP_ADDR=:8080
API_B_KAFKA_BROKERS=kafka:9092
API_B_LOG_LEVEL=warn
API_B_FEATURE_POW_VOTE=false
API_B_POW_ALGORITHM=sha256
API_B_POW_TTL_SECONDS=60
API_B_POW_BASE_DIFFICULTY_BITS=18
API_B_POW_MAX_DIFFICULTY_BITS=24
API_B_POW_ADAPTIVE_WINDOW_SECONDS=60
API_B_POW_TARGET_MS=3000
API_B_ANTIABUSE_STORE=valkey
API_B_VALKEY_ADDR=valkey:6379
API_B_VALKEY_DB=0
API_B_VALKEY_KEY_PREFIX=voting-platform-benchmark
API_B_KAFKA_TOPIC_VOTES_RAW=votes.raw
API_B_KAFKA_TOPIC_VOTINGS_CATALOG=votings.catalog
API_B_KAFKA_TOPIC_POLICY_CONTROL=voting-policy-control
API_B_KAFKA_TOPIC_RESULTS_SNAPSHOT=voting-results-snapshot
API_B_KAFKA_TOPIC_VOTING_CATALOG_LATEST=voting-catalog-latest
API_B_KAFKA_TOPIC_VOTING_POLICY_LATEST=voting-policy-latest
API_B_EDGE_PROXY_AUTH_HEADER=X-App-Edge-Auth

# Projector
PROJECTOR_HTTP_ADDR=:8081
PROJECTOR_KAFKA_BROKERS=kafka:9092
PROJECTOR_LOG_LEVEL=warn
PROJECTOR_SNAPSHOT_FLUSH_INTERVAL_MS=333
PROJECTOR_KAFKA_TOPIC_VOTES_RAW=votes.raw
PROJECTOR_KAFKA_TOPIC_VOTINGS_CATALOG=votings.catalog
PROJECTOR_KAFKA_TOPIC_POLICY_CONTROL=voting-policy-control
PROJECTOR_KAFKA_TOPIC_RESULTS_SNAPSHOT=voting-results-snapshot
PROJECTOR_KAFKA_TOPIC_VOTING_CATALOG_LATEST=voting-catalog-latest
PROJECTOR_KAFKA_TOPIC_VOTING_POLICY_LATEST=voting-policy-latest

# Frontend
FRONTEND_API_UPSTREAM_SCHEME=http
FRONTEND_API_UPSTREAM_HOST=api
FRONTEND_API_UPSTREAM_PORT=8080
BENCHMARK_LB_BIND_IP=127.0.0.1
BENCHMARK_LB_PORT=3002
FRONTEND_FEATURE_SLIDE_VOTE_MODE=off
FRONTEND_FEATURE_INTERACTION_TELEMETRY=false
FRONTEND_FEATURE_POW_VOTE=false
FRONTEND_VOTE_RATE_LIMIT=100000r/m
FRONTEND_RESULTS_RETRY_ATTEMPTS=1
FRONTEND_RESULTS_RETRY_INTERVAL_MS=50
FRONTEND_POST_CONFIRM_DELAY_MS=50

# Observability - Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_DASHBOARD_PROVIDER_NAME=Voting Platform Dashboards
GRAFANA_DASHBOARD_FOLDER=Voting Platform

# Observability - Prometheus
PROMETHEUS_SCRAPE_INTERVAL=5s
PROMETHEUS_EVALUATION_INTERVAL=5s

# Load Test
LOADTEST_API_BASE_URL=http://localhost:8080
LOADTEST_CONTROL_API_BASE_URL=http://localhost:8080
LOADTEST_MULTI_API_BASE_URL=http://localhost:3002
LOADTEST_SYNC_API_URLS=http://localhost:8080,http://localhost:8082
LOADTEST_SCENARIO=stress
LOADTEST_MODE=perf
LOADTEST_THINK_TIME=0
LOADTEST_CONSISTENCY_ITERATIONS=200
LOADTEST_CONSISTENCY_TIMEOUT_MS=20000
LOADTEST_CONSISTENCY_POLL_INTERVAL_MS=250
LOADTEST_TOPIC_VERIFY_TIMEOUT_MS=8000
LOADTEST_RUNTIME=podman
LOADTEST_K6_IMAGE=docker.io/grafana/k6:latest

# Benchmark-focused profile: minimizes protective overhead to maximize local throughput.
# Do not use this profile to describe protected, production-like behavior.
# API_POW_SECRET=benchmark-pow-secret
# API_B_POW_SECRET=benchmark-pow-secret
# API_VALKEY_PASSWORD=
# API_B_VALKEY_PASSWORD=
# LOADTEST_OUTPUT_DIR=docs/performance-artifacts/current-benchmark
