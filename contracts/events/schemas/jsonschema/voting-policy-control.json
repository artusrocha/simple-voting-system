{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://voting-platform.example/contracts/events/voting-policy-control.json",
  "title": "voting-policy-control",
  "type": "object",
  "additionalProperties": false,
  "required": ["policyEventId", "votingId", "targetType", "targetValue", "action", "effectiveMode", "createdAt"],
  "properties": {
    "policyEventId": { "type": "string", "minLength": 1 },
    "votingId": { "type": "string", "minLength": 1 },
    "targetType": { "type": "string", "enum": ["IP"] },
    "targetValue": { "type": "string", "minLength": 1 },
    "action": { "type": "string", "enum": ["ACTIVATE", "DEACTIVATE"] },
    "effectiveMode": { "type": "string", "enum": ["FORWARD_ONLY", "RETROACTIVE"] },
    "reason": { "type": "string" },
    "createdAt": { "type": "string", "format": "date-time" }
  }
}
