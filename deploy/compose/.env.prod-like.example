API_BIND_IP=127.0.0.1
API_PORT=8080
API_B_BIND_IP=127.0.0.1
API_B_PORT=8082

# Set both values to the same secret to require requests to traverse the frontend edge.
API_EDGE_PROXY_SHARED_SECRET=replace-me
API_B_EDGE_PROXY_SHARED_SECRET=replace-me
FRONTEND_API_EDGE_AUTH_SECRET=replace-me
API_EDGE_PROXY_AUTH_HEADER=X-App-Edge-Auth
API_B_EDGE_PROXY_AUTH_HEADER=X-App-Edge-Auth
